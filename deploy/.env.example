# ============================================================
# Variaveis de ambiente para o bot @previsaovr na VM Oracle
# ------------------------------------------------------------
# Copie este arquivo para .env e preencha com os valores reais:
#   cp .env.example .env && nano .env
# NUNCA faca commit do .env preenchido (ele esta no .gitignore).
# ============================================================

# ID da conta Instagram (numerico). Mesmo valor do Secret IG_USER_ID.
IG_USER_ID=

# Token de acesso de longa duracao da Instagram Graph API.
# Mesmo valor do Secret IG_ACCESS_TOKEN. Renove a cada ~60 dias.
IG_ACCESS_TOKEN=

# Usuario/repo do GitHub onde as imagens ficam publicas (raw.githubusercontent).
# Ex.: pabloramoa-dev/previsaovr-instagram
GITHUB_REPO=pabloramoa-dev/previsaovr-instagram

# Token do GitHub com permissao de push (para commitar as imagens geradas).
# Crie um Fine-grained PAT com Contents: Read and write apenas neste repo.
GITHUB_TOKEN=
